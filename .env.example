# Domain / URLs
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
STORAGE_PUBLIC_URL=http://localhost:9000
# Production examples:
# APP_PUBLIC_URL=https://www.mosfet.com.br
# API_PUBLIC_URL=https://api.mosfet.com.br
# STORAGE_PUBLIC_URL=https://storage.mosfet.com.br

# App / web
NEXT_PUBLIC_API_URL=http://localhost:3001
INTERNAL_API_URL=http://vestgo-api:3001
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Auth
NEXTAUTH_SECRET=vestgo-local-secret-change-me
AUTH_SECRET=vestgo-local-secret-change-me

# API
PORT=3001
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
JWT_SECRET=vestgo-jwt-secret
JWT_REFRESH_SECRET=vestgo-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Postgres
POSTGRES_DB=vestgo
POSTGRES_USER=vestgo
POSTGRES_PASSWORD=vestgo
DATABASE_URL=postgresql://vestgo:vestgo@vestgo-db:5432/vestgo

# Redis
REDIS_PASSWORD=vestgo_redis_password
REDIS_URL=redis://:vestgo_redis_password@vestgo-redis:6379

# MinIO / storage
MINIO_ENDPOINT=vestgo-storage
MINIO_PORT=9000
MINIO_ACCESS_KEY=vestgo_minio
MINIO_SECRET_KEY=vestgo_minio_secret
MINIO_BUCKET=vestgo-uploads
MINIO_CONSOLE_URL=http://localhost:9001

# Deploy / production images
WEB_IMAGE=ghcr.io/your-github-user-or-org/vestgo-web:latest
API_IMAGE=ghcr.io/your-github-user-or-org/vestgo-api:latest
NPM_EXTERNAL_NETWORK=rvproxy_npm_backend_network

# CI / CD examples
PORTAINER_WEBHOOK_URL=https://portainer.example.com/api/webhooks/your-webhook-id
WEB_HEALTHCHECK_URL=https://www.mosfet.com.br
API_HEALTHCHECK_URL=https://api.mosfet.com.br/health

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DONOR
  COLLECTION_POINT
  NGO
  ADMIN
}

enum DonationStatus {
  PENDING
  AT_POINT
  IN_TRANSIT
  DELIVERED
  DISTRIBUTED
  CANCELLED
}

enum ItemCategory {
  CLOTHING
  SHOES
  ACCESSORIES
  BAGS
  OTHER
}

enum PublicProfileState {
  DRAFT
  PENDING
  ACTIVE
  VERIFIED
}

enum OperationalPartnershipStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum NotificationType {
  DONATION_STATUS
  DONATION_POINTS
  BADGE_EARNED
  DONATION_CREATED_FOR_POINT
  PARTNERSHIP_REQUEST_RECEIVED
  PARTNERSHIP_STATUS_CHANGED
  PICKUP_REQUEST_CREATED
  PICKUP_REQUEST_RECEIVED
  PICKUP_REQUEST_STATUS_CHANGED
  PROFILE_APPROVAL_REQUIRED
  PROFILE_REVISION_PENDING
}

enum PickupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PublicProfileRevisionStatus {
  PENDING
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(DONOR)
  avatarUrl     String?
  coverImageUrl String?
  galleryImageUrls String[] @default([])
  phone         String?
  cpf           String?   @unique

  organizationName     String?
  cnpj                 String? @unique
  description          String?
  purpose              String?
  address              String?
  addressNumber        String?
  addressComplement    String?
  neighborhood         String?
  zipCode              String?
  city                 String?
  state                String?
  latitude             Float?
  longitude            Float?
  openingHours         String?
  openingSchedule      Json?
  openingHoursExceptions String?
  publicNotes          String?
  operationalNotes     String?
  accessibilityDetails String?
  accessibilityFeatures String[] @default([])
  verificationNotes    String?
  estimatedCapacity    String?
  serviceRegions       String[] @default([])
  rules                String[] @default([])
  nonAcceptedItems     String[] @default([])
  acceptedCategories   ItemCategory[] @default([])
  publicProfileState   PublicProfileState @default(DRAFT)
  verifiedAt           DateTime?
  pendingPublicRevision             Json?
  pendingPublicRevisionStatus       PublicProfileRevisionStatus?
  pendingPublicRevisionFields       String[] @default([])
  pendingPublicRevisionSubmittedAt  DateTime?
  pendingPublicRevisionReviewedAt   DateTime?
  pendingPublicRevisionReviewNotes  String?

  donations                       Donation[]               @relation("DonorDonations")
  collectedAt                     Donation[]               @relation("CollectionPointDonations")
  receivedAt                      Donation[]               @relation("NgoDonations")
  outgoingOperationalPartnerships OperationalPartnership[] @relation("CollectionPointOperationalPartnerships")
  incomingOperationalPartnerships OperationalPartnership[] @relation("NgoOperationalPartnerships")
  pickupRequestsToApprove         PickupRequest[]          @relation("CollectionPointPickupRequests")
  pickupRequestsRequested         PickupRequest[]          @relation("NgoPickupRequests")
  notifications                   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Donation {
  id          String         @id @default(cuid())
  code        String         @unique @default(cuid())
  status      DonationStatus @default(PENDING)

  donor   User   @relation("DonorDonations", fields: [donorId], references: [id])
  donorId String

  collectionPoint   User?   @relation("CollectionPointDonations", fields: [collectionPointId], references: [id])
  collectionPointId String?

  ngo   User?   @relation("NgoDonations", fields: [ngoId], references: [id])
  ngoId String?

  operationalPartnership   OperationalPartnership? @relation("DonationOperationalPartnership", fields: [operationalPartnershipId], references: [id])
  operationalPartnershipId String?

  items    DonationItem[]
  timeline DonationEvent[]

  notes       String?
  scheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("donations")
}

model OperationalPartnership {
  id                String                       @id @default(cuid())
  collectionPoint   User                         @relation("CollectionPointOperationalPartnerships", fields: [collectionPointId], references: [id], onDelete: Cascade)
  collectionPointId String
  ngo               User                         @relation("NgoOperationalPartnerships", fields: [ngoId], references: [id], onDelete: Cascade)
  ngoId             String
  status            OperationalPartnershipStatus @default(PENDING)
  isActive          Boolean                      @default(false)
  priority          Int                          @default(0)
  notes             String?

  donations Donation[] @relation("DonationOperationalPartnership")
  pickupRequests PickupRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([collectionPointId, ngoId])
  @@index([collectionPointId, status, priority])
  @@index([ngoId, status, priority])
  @@map("operational_partnerships")
}

model DonationItem {
  id         String   @id @default(cuid())
  donation   Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  donationId String

  name        String
  category    ItemCategory @default(CLOTHING)
  quantity    Int          @default(1)
  description String?
  imageUrl    String?
  weightKg    Float?

  @@map("donation_items")
}

model DonationEvent {
  id         String   @id @default(cuid())
  donation   Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  donationId String

  status      DonationStatus
  description String
  createdBy   String?
  location    String?

  createdAt DateTime @default(now())

  @@map("donation_events")
}

model Notification {
  id      String           @id @default(cuid())
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  type    NotificationType
  title   String
  body    String
  href    String?
  payload Json?
  readAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model PickupRequest {
  id                       String            @id @default(cuid())
  operationalPartnership   OperationalPartnership @relation(fields: [operationalPartnershipId], references: [id], onDelete: Cascade)
  operationalPartnershipId String
  collectionPoint          User              @relation("CollectionPointPickupRequests", fields: [collectionPointId], references: [id], onDelete: Cascade)
  collectionPointId        String
  ngo                      User              @relation("NgoPickupRequests", fields: [ngoId], references: [id], onDelete: Cascade)
  ngoId                    String
  status                   PickupRequestStatus @default(PENDING)
  requestedDate            DateTime?
  timeWindowStart          String?
  timeWindowEnd            String?
  notes                    String?
  responseNotes            String?
  respondedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collectionPointId, status, createdAt])
  @@index([ngoId, status, createdAt])
  @@index([operationalPartnershipId, status, createdAt])
  @@map("pickup_requests")
}

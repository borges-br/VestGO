// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  DONOR
  COLLECTION_POINT
  NGO
  ADMIN
}

enum DonationStatus {
  PENDING       // Cadastrada, aguardando entrega
  AT_POINT      // Entregue no ponto de coleta
  IN_TRANSIT    // Em trânsito para a ONG
  DELIVERED     // Entregue na ONG
  DISTRIBUTED   // Distribuída para as famílias
  CANCELLED     // Cancelada
}

enum ItemCategory {
  CLOTHING
  SHOES
  ACCESSORIES
  BAGS
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(DONOR)
  avatarUrl     String?
  phone         String?
  cpf           String?   @unique

  // Para pontos de coleta e ONGs
  organizationName  String?
  cnpj              String? @unique
  address           String?
  city              String?
  state             String?
  latitude          Float?
  longitude         Float?
  acceptedCategories ItemCategory[]

  donations     Donation[]  @relation("DonorDonations")
  collectedAt   Donation[]  @relation("CollectionPointDonations")
  receivedAt    Donation[]  @relation("NgoDonations")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Donation {
  id          String          @id @default(cuid())
  code        String          @unique @default(cuid()) // código de rastreio público
  status      DonationStatus  @default(PENDING)

  // Quem doou
  donor       User    @relation("DonorDonations", fields: [donorId], references: [id])
  donorId     String

  // Ponto de coleta escolhido
  collectionPoint     User?   @relation("CollectionPointDonations", fields: [collectionPointId], references: [id])
  collectionPointId   String?

  // ONG destino
  ngo       User?   @relation("NgoDonations", fields: [ngoId], references: [id])
  ngoId     String?

  items       DonationItem[]
  timeline    DonationEvent[]

  notes       String?
  scheduledAt DateTime?   // Data agendada para entrega no ponto

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("donations")
}

model DonationItem {
  id          String        @id @default(cuid())
  donation    Donation      @relation(fields: [donationId], references: [id], onDelete: Cascade)
  donationId  String

  name        String
  category    ItemCategory  @default(CLOTHING)
  quantity    Int           @default(1)
  description String?
  imageUrl    String?
  weightKg    Float?

  @@map("donation_items")
}

model DonationEvent {
  id          String    @id @default(cuid())
  donation    Donation  @relation(fields: [donationId], references: [id], onDelete: Cascade)
  donationId  String

  status      DonationStatus
  description String
  createdBy   String?   // userId de quem registrou
  location    String?

  createdAt   DateTime @default(now())

  @@map("donation_events")
}